# ==============================================================================
# VOICES KG v2 — Environment configuration
# Copy to .env and adjust as needed. Never commit .env.
# ==============================================================================

# ---- Deployment flags ---------------------------------------------------------

# When true, the Streamlit app is gated behind Caddy's forward_auth → FastAPI.
# When false, the app is publicly accessible (good for post-acceptance release).
# The /admin/* path is ALWAYS gated regardless of this value.
REQUIRE_AUTH=true

# Public base URL. Set to https://your-domain.example for a real VM deploy.
# Locally we run on self-signed TLS via Caddy's internal CA.
PUBLIC_BASE_URL=https://localhost:8443

# ---- Secrets (change before deploying) ---------------------------------------

JWT_SECRET=change-me-in-production
FUSEKI_ADMIN_PASSWORD=change-me-in-production
MEILI_MASTER_KEY=change-me-in-production

# ---- First admin user (consumed by scripts/seed_admin.py) --------------------

ADMIN_EMAIL=admin@voices.local
ADMIN_PASSWORD=change-me-in-production

# ---- Ports (host-exposed) ----------------------------------------------------

CADDY_HTTPS_PORT=8443
CADDY_HTTP_PORT=8080
# Fuseki is exposed directly for host-side debugging / SPARQL curl.
FUSEKI_HOST_PORT=3032

# ---- Paths --------------------------------------------------------------------

# Path to v1 data (read-only source for re-materialization)
V1_OUTPUT_DIR=/mnt/d/Projets/voices/workspace/KG2026.paper/output

# ---- Tuning -------------------------------------------------------------------

# Fuseki JVM heap. For 17M+ quads on a dev box, 6G is plenty.
FUSEKI_JVM_ARGS=-Xmx6g -Xms2g

# Streamlit + FastAPI worker counts (set 1 for dev).
STREAMLIT_WORKERS=1
UVICORN_WORKERS=2

<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/voices/ontology#"
     xml:base="https://w3id.org/voices/ontology"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://w3id.org/voices/ontology#">
        <owl:versionIRI rdf:resource="https://w3id.org/voices/ontology/2.1"/>
        <owl:imports rdf:resource="https://w3id.org/voices/ontology/imports/cidoc-crm"/>
        <owl:imports rdf:resource="https://w3id.org/voices/ontology/imports/ma-ont"/>
        <owl:imports rdf:resource="https://w3id.org/voices/ontology/imports/mfoem"/>
        <owl:imports rdf:resource="https://w3id.org/voices/ontology/imports/oa"/>
        <owl:imports rdf:resource="https://w3id.org/voices/ontology/imports/time"/>
        <terms:creator>Cédric Pruski</terms:creator>
        <terms:creator>Gabor Mihaly Toth</terms:creator>
        <terms:creator>Marcos Da Silveira</terms:creator>
        <terms:creator>Mohamed Laib</terms:creator>
        <terms:description xml:lang="en">Unified VOICES ontology for Holocaust survivor testimony knowledge graphs.
    Thesaurus-free public variant. External standards: CIDOC-CRM, OWL-Time,
    MFOEM, Web Annotation, PROV-O, Media Ontology.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-04</terms:issued>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-04</terms:modified>
        <terms:publisher>Luxembourg Institute of Science and Technology (LIST)</terms:publisher>
        <terms:title xml:lang="en">VOICES Ontology</terms:title>
        <vann:preferredNamespacePrefix>voices</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://w3id.org/voices/ontology#</vann:preferredNamespaceUri>
        <rdfs:comment xml:lang="en">Unified VOICES ontology for Holocaust survivor testimony knowledge graphs.
    Thesaurus-free public variant. External standards: CIDOC-CRM, OWL-Time,
    MFOEM, Web Annotation, PROV-O, Media Ontology.</rdfs:comment>
        <rdfs:label xml:lang="en">VOICES Ontology</rdfs:label>
        <owl:versionInfo xml:lang="en">2.1-unified</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/issued -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/issued"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/modified -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/modified"/>
    


    <!-- http://purl.org/dc/terms/publisher -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/publisher"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.cidoc-crm.org/cidoc-crm/P11_had_participant -->


    <owl:ObjectProperty rdf:about="http://www.cidoc-crm.org/cidoc-crm/P11_had_participant"/>
    


    <!-- http://www.cidoc-crm.org/cidoc-crm/P148_has_component -->


    <owl:ObjectProperty rdf:about="http://www.cidoc-crm.org/cidoc-crm/P148_has_component"/>
    


    <!-- http://www.cidoc-crm.org/cidoc-crm/P17_was_motivated_by -->


    <owl:ObjectProperty rdf:about="http://www.cidoc-crm.org/cidoc-crm/P17_was_motivated_by"/>
    


    <!-- http://www.cidoc-crm.org/cidoc-crm/P2_has_type -->


    <owl:ObjectProperty rdf:about="http://www.cidoc-crm.org/cidoc-crm/P2_has_type"/>
    


    <!-- http://www.cidoc-crm.org/cidoc-crm/P32_used_general_technique -->


    <owl:ObjectProperty rdf:about="http://www.cidoc-crm.org/cidoc-crm/P32_used_general_technique"/>
    


    <!-- http://www.cidoc-crm.org/cidoc-crm/P4_has_time-span -->


    <owl:ObjectProperty rdf:about="http://www.cidoc-crm.org/cidoc-crm/P4_has_time-span"/>
    


    <!-- http://www.cidoc-crm.org/cidoc-crm/P67_refers_to -->


    <owl:ObjectProperty rdf:about="http://www.cidoc-crm.org/cidoc-crm/P67_refers_to"/>
    


    <!-- http://www.cidoc-crm.org/cidoc-crm/P7_took_place_at -->


    <owl:ObjectProperty rdf:about="http://www.cidoc-crm.org/cidoc-crm/P7_took_place_at"/>
    


    <!-- http://www.w3.org/ns/oa#hasBody -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/oa#hasBody"/>
    


    <!-- https://w3id.org/voices/ontology#alignsWithHistoricalEvent -->


    <owl:ObjectProperty rdf:about="https://w3id.org/voices/ontology#alignsWithHistoricalEvent">
        <rdfs:domain rdf:resource="https://w3id.org/voices/ontology#NarratedEvent"/>
        <rdfs:range rdf:resource="https://w3id.org/voices/ontology#HistoricalEvent"/>
        <rdfs:label xml:lang="en">aligns with historical event</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/voices/ontology#hasActivity -->


    <owl:ObjectProperty rdf:about="https://w3id.org/voices/ontology#hasActivity">
        <rdfs:subPropertyOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/P2_has_type"/>
        <rdfs:domain rdf:resource="https://w3id.org/voices/ontology#NarratedEvent"/>
        <rdfs:range rdf:resource="https://w3id.org/voices/ontology#Activity"/>
        <rdfs:label xml:lang="en">has activity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/voices/ontology#hasCause -->


    <owl:ObjectProperty rdf:about="https://w3id.org/voices/ontology#hasCause">
        <rdfs:subPropertyOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/P17_was_motivated_by"/>
        <rdfs:domain rdf:resource="https://w3id.org/voices/ontology#NarratedEvent"/>
        <rdfs:range rdf:resource="https://w3id.org/voices/ontology#Cause"/>
        <rdfs:label xml:lang="en">has cause</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/voices/ontology#hasEmbedding -->


    <owl:ObjectProperty rdf:about="https://w3id.org/voices/ontology#hasEmbedding">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/voices/ontology#InterviewSegment"/>
                    <rdf:Description rdf:about="https://w3id.org/voices/ontology#NarratedEvent"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/voices/ontology#Embedding"/>
        <rdfs:label xml:lang="en">has embedding</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/voices/ontology#hasEmotion -->


    <owl:ObjectProperty rdf:about="https://w3id.org/voices/ontology#hasEmotion">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/oa#hasBody"/>
        <rdfs:domain rdf:resource="https://w3id.org/voices/ontology#NarratedEvent"/>
        <rdfs:range rdf:resource="https://w3id.org/voices/ontology#EmotionAnnotation"/>
        <rdfs:label xml:lang="en">has emotion</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/voices/ontology#hasLocation -->


    <owl:ObjectProperty rdf:about="https://w3id.org/voices/ontology#hasLocation">
        <rdfs:subPropertyOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/P7_took_place_at"/>
        <rdfs:domain rdf:resource="https://w3id.org/voices/ontology#NarratedEvent"/>
        <rdfs:range rdf:resource="http://www.cidoc-crm.org/cidoc-crm/E53_Place"/>
        <rdfs:label xml:lang="en">has location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/voices/ontology#hasMediaFragment -->


    <owl:ObjectProperty rdf:about="https://w3id.org/voices/ontology#hasMediaFragment">
        <rdfs:domain rdf:resource="https://w3id.org/voices/ontology#InterviewSegment"/>
        <rdfs:range rdf:resource="https://w3id.org/voices/ontology#MediaFragment"/>
        <rdfs:comment xml:lang="en">Links an interview segment to a temporal clip of the audiovisual recording.</rdfs:comment>
        <rdfs:label xml:lang="en">has media fragment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/voices/ontology#hasMediaResource -->


    <owl:ObjectProperty rdf:about="https://w3id.org/voices/ontology#hasMediaResource">
        <rdfs:domain rdf:resource="https://w3id.org/voices/ontology#Interview"/>
        <rdfs:range rdf:resource="https://w3id.org/voices/ontology#MediaResource"/>
        <rdfs:comment xml:lang="en">Links an interview to the audiovisual recording representing it.</rdfs:comment>
        <rdfs:label xml:lang="en">has media resource</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/voices/ontology#hasMode -->


    <owl:ObjectProperty rdf:about="https://w3id.org/voices/ontology#hasMode">
        <rdfs:subPropertyOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/P32_used_general_technique"/>
        <rdfs:domain rdf:resource="https://w3id.org/voices/ontology#NarratedEvent"/>
        <rdfs:range rdf:resource="https://w3id.org/voices/ontology#Mode"/>
        <rdfs:label xml:lang="en">has mode</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/voices/ontology#hasParticipant -->


    <owl:ObjectProperty rdf:about="https://w3id.org/voices/ontology#hasParticipant">
        <rdfs:subPropertyOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/P11_had_participant"/>
        <rdfs:domain rdf:resource="https://w3id.org/voices/ontology#NarratedEvent"/>
        <rdfs:range rdf:resource="https://w3id.org/voices/ontology#Person"/>
        <rdfs:label xml:lang="en">has participant</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/voices/ontology#hasPhysiologicalProcess -->


    <owl:ObjectProperty rdf:about="https://w3id.org/voices/ontology#hasPhysiologicalProcess">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/oa#hasBody"/>
        <rdfs:domain rdf:resource="https://w3id.org/voices/ontology#InterviewSegment"/>
        <rdfs:range rdf:resource="https://w3id.org/voices/ontology#PhysiologicalProcess"/>
        <rdfs:comment xml:lang="en">Links an interview segment to an observed physiological process (e.g. crying).</rdfs:comment>
        <rdfs:label xml:lang="en">has physiological process</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/voices/ontology#hasSegment -->


    <owl:ObjectProperty rdf:about="https://w3id.org/voices/ontology#hasSegment">
        <rdfs:subPropertyOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/P148_has_component"/>
        <rdfs:domain rdf:resource="https://w3id.org/voices/ontology#Interview"/>
        <rdfs:range rdf:resource="https://w3id.org/voices/ontology#InterviewSegment"/>
        <rdfs:label xml:lang="en">has segment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/voices/ontology#hasTimeInterval -->


    <owl:ObjectProperty rdf:about="https://w3id.org/voices/ontology#hasTimeInterval">
        <rdfs:subPropertyOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/P4_has_time-span"/>
        <rdfs:domain rdf:resource="https://w3id.org/voices/ontology#NarratedEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:label xml:lang="en">has time interval</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/voices/ontology#segmentRefersToEvent -->


    <owl:ObjectProperty rdf:about="https://w3id.org/voices/ontology#segmentRefersToEvent">
        <rdfs:subPropertyOf rdf:resource="http://www.cidoc-crm.org/cidoc-crm/P67_refers_to"/>
        <rdfs:domain rdf:resource="https://w3id.org/voices/ontology#InterviewSegment"/>
        <rdfs:range rdf:resource="https://w3id.org/voices/ontology#NarratedEvent"/>
        <rdfs:label xml:lang="en">segment refers to event</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/voices/ontology#similarTo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/voices/ontology#similarTo">
        <rdfs:domain rdf:resource="https://w3id.org/voices/ontology#Embedding"/>
        <rdfs:range rdf:resource="https://w3id.org/voices/ontology#Embedding"/>
        <rdfs:label xml:lang="en">semantically similar to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/voices/ontology#collectionOwner -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#collectionOwner">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Owning collection or archive of an interview.</rdfs:comment>
        <rdfs:label xml:lang="en">collection owner</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#communityId -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#communityId">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Identifier of the community assigned by community detection.</rdfs:comment>
        <rdfs:label xml:lang="en">community id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#computedWith -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#computedWith">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name of the model or algorithm used to compute a result.</rdfs:comment>
        <rdfs:label xml:lang="en">computed with model</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#confidence -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#confidence">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Confidence score for the annotated statement (0.0-1.0).</rdfs:comment>
        <rdfs:label xml:lang="en">confidence</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#detectionMethod -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#detectionMethod">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Algorithm used for community detection (e.g. louvain).</rdfs:comment>
        <rdfs:label xml:lang="en">detection method</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#embeddingDim -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#embeddingDim">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Dimensionality of an embedding vector.</rdfs:comment>
        <rdfs:label xml:lang="en">embedding dimension</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#embeddingModel -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#embeddingModel">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name of the model used to compute an embedding vector.</rdfs:comment>
        <rdfs:label xml:lang="en">embedding model</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#emotionCategory -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#emotionCategory">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Controlled emotion category label of an emotion annotation.</rdfs:comment>
        <rdfs:label xml:lang="en">emotion category</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#endTimestampMs -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#endTimestampMs">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">End time of a segment in milliseconds from recording start.</rdfs:comment>
        <rdfs:label xml:lang="en">end timestamp (ms)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#extractionStep -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#extractionStep">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Step in the extraction pipeline that produced this annotation.</rdfs:comment>
        <rdfs:label xml:lang="en">extraction pipeline step</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#gender -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#gender">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Recorded gender of a person, where available.</rdfs:comment>
        <rdfs:label xml:lang="en">gender</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#hasArousal -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#hasArousal">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Calibrated arousal score of an emotion annotation.</rdfs:comment>
        <rdfs:label xml:lang="en">has arousal</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#hasIntensity -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#hasIntensity">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Intensity score of an emotion or physiological annotation.</rdfs:comment>
        <rdfs:label xml:lang="en">has intensity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#hasValence -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#hasValence">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Calibrated valence score of an emotion annotation.</rdfs:comment>
        <rdfs:label xml:lang="en">has valence</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#interviewId -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#interviewId">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Numeric identifier of the interview.</rdfs:comment>
        <rdfs:label xml:lang="en">interview id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#interviewSummary -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#interviewSummary">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Short textual summary of the interview.</rdfs:comment>
        <rdfs:label xml:lang="en">interview summary</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#linkConfidence -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#linkConfidence">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Confidence score of an outward authority link.</rdfs:comment>
        <rdfs:label xml:lang="en">link confidence</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#matchConfidence -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#matchConfidence">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">Confidence score for an entity match or alignment.</rdfs:comment>
        <rdfs:label xml:lang="en">match confidence</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#matchMethod -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#matchMethod">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Method used to match or link an entity (e.g. exact_label, local_mint, external_alignment).</rdfs:comment>
        <rdfs:label xml:lang="en">match method</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#matchedPattern -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#matchedPattern">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The regex pattern that triggered a classification.</rdfs:comment>
        <rdfs:label xml:lang="en">matched regex pattern</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/voices/ontology#media_url -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/voices/ontology#media_url">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">URL of the audiovisual media resource.</rdfs:comment>
        <rdfs:label xml:lang="en">media URL</rdfs:label>
    </owl:DatatypeProperty>
    



@prefix :        <#> .
@prefix fuseki:  <http://jena.apache.org/fuseki#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tdb2:    <http://jena.apache.org/2016/tdb#> .
@prefix ja:      <http://jena.apache.org/2005-11-assembler#> .
@prefix text:    <http://jena.apache.org/text#> .

# ── Dataset with TDB2 + Lucene text index ──────────────────────────────────

:service a fuseki:Service ;
    fuseki:name "voices" ;
    fuseki:serviceQuery "query", "sparql" ;
    fuseki:serviceUpdate "update" ;
    fuseki:serviceUpload "upload" ;
    fuseki:serviceReadGraphStore "get" ;
    fuseki:serviceReadWriteGraphStore "data" ;
    fuseki:dataset :textDataset .

:textDataset a text:TextDataset ;
    text:dataset :tdbDataset ;
    text:index :indexLucene .

:tdbDataset a tdb2:DatasetTDB2 ;
    tdb2:location "/fuseki/databases/voices" ;
    tdb2:unionDefaultGraph true .

:indexLucene a text:TextIndexLucene ;
    text:directory "/fuseki/databases/voices-lucene" ;
    text:storeValues true ;
    text:entityMap :entMap .

# Index rdfs:label on any resource; this is what the dropdowns and
# explore-page label lookups will use. The dataset is thesaurus-free, so
# no SKOS labels are indexed.
:entMap a text:EntityMap ;
    text:entityField "uri" ;
    text:defaultField "text" ;
    text:map (
        [ text:field "text" ; text:predicate rdfs:label ]
    ) .

@prefix voices: <https://w3id.org/voices/ontology#> .
@prefix place:  <urn:voices:place:> .
@prefix crm:    <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix time:   <http://www.w3.org/2006/time#> .
@prefix ma:     <http://www.w3.org/ns/ma-ont#> .
@prefix oa:     <http://www.w3.org/ns/oa#> .
@prefix emo:    <http://purl.obolibrary.org/obo/MFOEM_> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann:   <http://purl.org/vocab/vann/> .

###################################################################
# VOICES Ontology v2.1 — Unified (merges v1.2 + KG0226 extensions)
# Public / thesaurus-free variant. All SFI (voices.uni.lu/vocab/term/)
# references removed; places are now locally minted urn:voices:place:
# IRIs. External alignment triples live in voices-alignment-v2.ttl.
#
# v2.1 changes vs v2.0:
#  - 3 classes (Activity, Mode, Cause) declared rdfs:subClassOf crm:E55_Type
#  - 7 object properties given rdfs:subPropertyOf to CIDOC-CRM / W3C OA
#    parent predicates, lifting formal reuse from 3/15 to 10/15
#  - 2 dead datatype properties (mentionWeight, mentionSource) removed
#  - No instance-data impact: all changes are metadata-only
###################################################################

voices: a owl:Ontology ;
    rdfs:label "VOICES Ontology"@en ;
    dcterms:title "VOICES Ontology"@en ;
    vann:preferredNamespacePrefix "voices" ;
    vann:preferredNamespaceUri "https://w3id.org/voices/ontology#" ;
    owl:versionInfo "2.1-unified"@en ;
    owl:versionIRI <https://w3id.org/voices/ontology/2.1> ;
    dcterms:issued "2026-05-04"^^xsd:date ;
    dcterms:modified "2026-05-04"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:creator "Cédric Pruski", "Mohamed Laib", "Marcos Da Silveira", "Gabor Mihaly Toth" ;
    dcterms:publisher "Luxembourg Institute of Science and Technology (LIST)" ;
    dcterms:description """Unified VOICES ontology for Holocaust survivor testimony knowledge graphs.
    Thesaurus-free public variant. External standards: CIDOC-CRM, OWL-Time,
    MFOEM, Web Annotation, PROV-O, Media Ontology."""@en ;
    rdfs:comment """Unified VOICES ontology for Holocaust survivor testimony knowledge graphs.
    Thesaurus-free public variant. External standards: CIDOC-CRM, OWL-Time,
    MFOEM, Web Annotation, PROV-O, Media Ontology."""@en ;
    owl:imports crm:, time:,
                <http://www.w3.org/ns/ma-ont>, <http://www.w3.org/ns/oa#>,
                <http://www.w3.org/ns/prov-o>, <http://purl.obolibrary.org/obo/MFOEM.owl> .

# === Core Classes ===

voices:Interview a owl:Class ;
    rdfs:subClassOf crm:E31_Document ;
    rdfs:label "Interview"@en ;
    rdfs:comment "A recorded oral testimony session grouped into several segments."@en .

voices:Person a owl:Class ;
    rdfs:subClassOf crm:E21_Person ;
    rdfs:label "Person"@en ;
    rdfs:comment "A human participant involved in the testimony or event."@en .

voices:InterviewSegment a owl:Class ;
    rdfs:subClassOf crm:E33_Linguistic_Object ;
    rdfs:label "Interview Segment"@en ;
    rdfs:comment "A time-bounded transcript fragment describing events, entities, and feelings."@en .

voices:NarratedEvent a owl:Class ;
    rdfs:subClassOf crm:E5_Event ;
    rdfs:label "Narrated Event"@en ;
    rdfs:comment "A life or historical episode described by the survivor, linked to participants, place, time, and emotions."@en .

voices:HistoricalEvent a owl:Class ;
    rdfs:subClassOf crm:E5_Event ;
    rdfs:label "Historical Event"@en ;
    rdfs:comment "A canonical historical event (e.g. Kristallnacht, Camp Liberation) for alignment."@en .

voices:Activity a owl:Class ;
    rdfs:subClassOf crm:E55_Type ;
    rdfs:label "Activity"@en ;
    rdfs:comment "Type of action described (deportation, forced labor, escape, etc.)."@en .

voices:Mode a owl:Class ;
    rdfs:subClassOf crm:E55_Type ;
    rdfs:label "Mode"@en ;
    rdfs:comment "Manner or mechanism of an event (by train, on foot, etc.)."@en .

voices:Cause a owl:Class ;
    rdfs:subClassOf crm:E55_Type ;
    rdfs:label "Cause"@en ;
    rdfs:comment "Reason or circumstance that led to the event."@en .

voices:Annotation a owl:Class ;
    rdfs:subClassOf oa:Annotation ;
    rdfs:label "Annotation"@en ;
    rdfs:comment "A Web Annotation attaching an interpretive body to a narrated event or interview segment."@en .

# v2.1: corrected MFOEM IRI 0000001 -> 000001 (MFOEM uses 6-digit local IDs;
# MFOEM_000001 = "emotion process"). 7-digit form did not resolve (R3).
voices:EmotionAnnotation a owl:Class ;
    rdfs:subClassOf voices:Annotation, emo:000001 ;
    rdfs:label "Emotion Annotation"@en ;
    rdfs:comment "An annotation associating a narrated event with an MFOEM emotion category and valence/arousal scores."@en .

voices:Embedding a owl:Class ;
    rdfs:label "Embedding"@en ;
    rdfs:comment "Numeric embedding representing semantic vectors for events."@en .

# v2.1: local class for observable physiological expressions during narration
# (crying, silence, laughter). Replaces an incorrect MFOEM emotion term that was
# previously used as the range of hasPhysiologicalProcess (R3).
voices:PhysiologicalProcess a owl:Class ;
    rdfs:label "Physiological Process"@en ;
    rdfs:comment "An observable physiological expression during narration, such as crying, silence, or laughter, detected from transcriber annotations."@en .

voices:MediaResource a owl:Class ;
    rdfs:subClassOf ma:MediaResource ;
    rdfs:label "Media Resource"@en .

voices:MediaFragment a owl:Class ;
    rdfs:subClassOf ma:MediaFragment ;
    rdfs:label "Media Fragment"@en .

# === Object Properties ===

voices:hasSegment a owl:ObjectProperty ;
    rdfs:domain voices:Interview ; rdfs:range voices:InterviewSegment ;
    rdfs:subPropertyOf crm:P148_has_component ;
    rdfs:label "has segment"@en .

voices:segmentRefersToEvent a owl:ObjectProperty ;
    rdfs:domain voices:InterviewSegment ; rdfs:range voices:NarratedEvent ;
    rdfs:subPropertyOf crm:P67_refers_to ;
    rdfs:label "segment refers to event"@en .

voices:hasParticipant a owl:ObjectProperty ;
    rdfs:domain voices:NarratedEvent ; rdfs:range voices:Person ;
    rdfs:subPropertyOf crm:P11_had_participant ;
    rdfs:label "has participant"@en .

voices:hasLocation a owl:ObjectProperty ;
    rdfs:domain voices:NarratedEvent ;
    rdfs:range crm:E53_Place ;
    rdfs:subPropertyOf crm:P7_took_place_at ;
    rdfs:label "has location"@en .

voices:hasActivity a owl:ObjectProperty ;
    rdfs:domain voices:NarratedEvent ;
    rdfs:range voices:Activity ;
    rdfs:subPropertyOf crm:P2_has_type ;
    rdfs:label "has activity"@en .

voices:hasMode a owl:ObjectProperty ;
    rdfs:domain voices:NarratedEvent ;
    rdfs:range voices:Mode ;
    rdfs:subPropertyOf crm:P32_used_general_technique ;
    rdfs:label "has mode"@en .

voices:hasCause a owl:ObjectProperty ;
    rdfs:domain voices:NarratedEvent ;
    rdfs:range voices:Cause ;
    rdfs:subPropertyOf crm:P17_was_motivated_by ;
    rdfs:label "has cause"@en .

voices:hasEmotion a owl:ObjectProperty ;
    rdfs:domain voices:NarratedEvent ; rdfs:range voices:EmotionAnnotation ;
    rdfs:subPropertyOf oa:hasBody ;
    rdfs:label "has emotion"@en .

voices:hasPhysiologicalProcess a owl:ObjectProperty ;
    rdfs:domain voices:InterviewSegment ; rdfs:range voices:PhysiologicalProcess ;
    rdfs:subPropertyOf oa:hasBody ;
    rdfs:label "has physiological process"@en ;
    rdfs:comment "Links an interview segment to an observed physiological process (e.g. crying)."@en .

voices:hasTimeInterval a owl:ObjectProperty ;
    rdfs:domain voices:NarratedEvent ; rdfs:range time:Interval ;
    rdfs:subPropertyOf crm:P4_has_time-span ;
    rdfs:label "has time interval"@en .

voices:alignsWithHistoricalEvent a owl:ObjectProperty ;
    rdfs:domain voices:NarratedEvent ; rdfs:range voices:HistoricalEvent ;
    rdfs:label "aligns with historical event"@en .

voices:hasEmbedding a owl:ObjectProperty ;
    rdfs:domain [ owl:unionOf ( voices:NarratedEvent voices:InterviewSegment ) ] ;
    rdfs:range voices:Embedding ;
    rdfs:label "has embedding"@en .

voices:similarTo a owl:ObjectProperty ;
    rdfs:domain voices:Embedding ; rdfs:range voices:Embedding ;
    rdfs:label "semantically similar to"@en .

voices:hasMediaResource a owl:ObjectProperty ;
    rdfs:domain voices:Interview ; rdfs:range voices:MediaResource ;
    rdfs:label "has media resource"@en ;
    rdfs:comment "Links an interview to the audiovisual recording representing it."@en .

voices:hasMediaFragment a owl:ObjectProperty ;
    rdfs:domain voices:InterviewSegment ; rdfs:range voices:MediaFragment ;
    rdfs:label "has media fragment"@en ;
    rdfs:comment "Links an interview segment to a temporal clip of the audiovisual recording."@en .

# === Datatype Properties ===

# v2.1: rdfs:label + rdfs:comment added to every datatype property (R3).

voices:interviewId a owl:DatatypeProperty ; rdfs:range xsd:integer ;
    rdfs:label "interview id"@en ; rdfs:comment "Numeric identifier of the interview."@en .
voices:utteranceId a owl:DatatypeProperty ; rdfs:range xsd:string ;
    rdfs:label "utterance id"@en ; rdfs:comment "Identifier of the source utterance of a segment."@en .
voices:segmentOrdinal a owl:DatatypeProperty ; rdfs:range xsd:integer ;
    rdfs:label "segment ordinal"@en ; rdfs:comment "Ordinal position of a segment within its interview."@en .
voices:transcriptText a owl:DatatypeProperty ; rdfs:range xsd:string ;
    rdfs:label "transcript text"@en ; rdfs:comment "Verbatim transcript text of a segment (not redistributed publicly)."@en .
voices:speakerCode a owl:DatatypeProperty ; rdfs:range xsd:string ;
    rdfs:label "speaker code"@en ; rdfs:comment "Speaker label of a segment (e.g. interviewer vs interviewee)."@en .
voices:startTimestampMs a owl:DatatypeProperty ; rdfs:range xsd:integer ;
    rdfs:label "start timestamp (ms)"@en ; rdfs:comment "Start time of a segment in milliseconds from recording start."@en .
voices:endTimestampMs a owl:DatatypeProperty ; rdfs:range xsd:integer ;
    rdfs:label "end timestamp (ms)"@en ; rdfs:comment "End time of a segment in milliseconds from recording start."@en .
voices:whatText a owl:DatatypeProperty ; rdfs:range xsd:string ;
    rdfs:label "what text"@en ; rdfs:comment "Raw free-text activity description extracted for a narrated event."@en .
voices:whenText a owl:DatatypeProperty ; rdfs:range xsd:string ;
    rdfs:label "when text"@en ; rdfs:comment "Raw free-text temporal reference extracted for a narrated event."@en .
voices:temporalBucket a owl:DatatypeProperty ; rdfs:range xsd:string ;
    rdfs:label "temporal bucket"@en ; rdfs:comment "Historical-period bucket assigned to a narrated event's time interval."@en .
voices:embeddingModel a owl:DatatypeProperty ; rdfs:range xsd:string ;
    rdfs:label "embedding model"@en ; rdfs:comment "Name of the model used to compute an embedding vector."@en .
voices:embeddingDim a owl:DatatypeProperty ; rdfs:range xsd:integer ;
    rdfs:label "embedding dimension"@en ; rdfs:comment "Dimensionality of an embedding vector."@en .
voices:hasValence a owl:DatatypeProperty ; rdfs:range xsd:float ;
    rdfs:label "has valence"@en ; rdfs:comment "Calibrated valence score of an emotion annotation."@en .
voices:hasArousal a owl:DatatypeProperty ; rdfs:range xsd:float ;
    rdfs:label "has arousal"@en ; rdfs:comment "Calibrated arousal score of an emotion annotation."@en .
voices:hasIntensity a owl:DatatypeProperty ; rdfs:range xsd:float ;
    rdfs:label "has intensity"@en ; rdfs:comment "Intensity score of an emotion or physiological annotation."@en .
voices:emotionCategory a owl:DatatypeProperty ; rdfs:range xsd:string ;
    rdfs:label "emotion category"@en ; rdfs:comment "Controlled emotion category label of an emotion annotation."@en .
voices:similarityScore a owl:DatatypeProperty ; rdfs:range xsd:float ;
    rdfs:label "similarity score"@en ; rdfs:comment "Cosine-similarity score of a similarTo relation."@en .
voices:communityId a owl:DatatypeProperty ; rdfs:range xsd:integer ;
    rdfs:label "community id"@en ; rdfs:comment "Identifier of the community assigned by community detection."@en .
voices:linkConfidence a owl:DatatypeProperty ; rdfs:range xsd:float ;
    rdfs:label "link confidence"@en ; rdfs:comment "Confidence score of an outward authority link."@en .
voices:gender a owl:DatatypeProperty ; rdfs:range xsd:string ;
    rdfs:label "gender"@en ; rdfs:comment "Recorded gender of a person, where available."@en .
voices:collectionOwner a owl:DatatypeProperty ; rdfs:range xsd:string ;
    rdfs:label "collection owner"@en ; rdfs:comment "Owning collection or archive of an interview."@en .
voices:recordingYear a owl:DatatypeProperty ; rdfs:range xsd:string ;
    rdfs:label "recording year"@en ; rdfs:comment "Year the interview was recorded."@en .
voices:testimonyTitle a owl:DatatypeProperty ; rdfs:range xsd:string ;
    rdfs:label "testimony title"@en ; rdfs:comment "Title of the testimony."@en .
voices:interviewSummary a owl:DatatypeProperty ; rdfs:range xsd:string ;
    rdfs:label "interview summary"@en ; rdfs:comment "Short textual summary of the interview."@en .
voices:media_url a owl:DatatypeProperty ; rdfs:range xsd:string ;
    rdfs:label "media URL"@en ; rdfs:comment "URL of the audiovisual media resource."@en .
voices:thumbnail_url a owl:DatatypeProperty ; rdfs:range xsd:string ;
    rdfs:label "thumbnail URL"@en ; rdfs:comment "URL of a thumbnail image for the media resource."@en .
voices:processName a owl:DatatypeProperty ; rdfs:domain voices:PhysiologicalProcess ; rdfs:range xsd:string ;
    rdfs:label "process name"@en ; rdfs:comment "Name of the physiological process (e.g. crying, silence, laughter)."@en .
voices:processIntensity a owl:DatatypeProperty ; rdfs:domain voices:PhysiologicalProcess ; rdfs:range xsd:float ;
    rdfs:label "process intensity"@en ; rdfs:comment "Graded intensity of the observed physiological process."@en .

# === RDF-star Annotation Properties ===

voices:confidence a owl:DatatypeProperty ;
    rdfs:label "confidence"@en ;
    rdfs:comment "Confidence score for the annotated statement (0.0-1.0)."@en ;
    rdfs:range xsd:float .

voices:method a owl:DatatypeProperty ;
    rdfs:label "extraction method"@en ;
    rdfs:comment "Method used to produce the annotation (regex, llm_extraction, etc.)."@en ;
    rdfs:range xsd:string .

voices:matchMethod a owl:DatatypeProperty ;
    rdfs:label "match method"@en ;
    rdfs:comment "Method used to match or link an entity (e.g. exact_label, local_mint, external_alignment)."@en ;
    rdfs:range xsd:string .

voices:matchConfidence a owl:DatatypeProperty ;
    rdfs:label "match confidence"@en ;
    rdfs:comment "Confidence score for an entity match or alignment."@en ;
    rdfs:range xsd:float .

voices:matchedPattern a owl:DatatypeProperty ;
    rdfs:label "matched regex pattern"@en ;
    rdfs:comment "The regex pattern that triggered a classification."@en ;
    rdfs:range xsd:string .

voices:precision a owl:DatatypeProperty ;
    rdfs:label "temporal precision"@en ;
    rdfs:comment "Precision level of a temporal annotation (month, year, year_range, relative, unknown)."@en ;
    rdfs:range xsd:string .

voices:parsedFrom a owl:DatatypeProperty ;
    rdfs:label "parsed from expression"@en ;
    rdfs:comment "The raw text expression from which temporal information was parsed."@en ;
    rdfs:range xsd:string .

voices:parseConfidence a owl:DatatypeProperty ;
    rdfs:label "parse confidence"@en ;
    rdfs:comment "Confidence of a temporal parse result."@en ;
    rdfs:range xsd:float .

voices:computedWith a owl:DatatypeProperty ;
    rdfs:label "computed with model"@en ;
    rdfs:comment "Name of the model or algorithm used to compute a result."@en ;
    rdfs:range xsd:string .

voices:detectionMethod a owl:DatatypeProperty ;
    rdfs:label "detection method"@en ;
    rdfs:comment "Algorithm used for community detection (e.g. louvain)."@en ;
    rdfs:range xsd:string .

voices:extractionStep a owl:DatatypeProperty ;
    rdfs:label "extraction pipeline step"@en ;
    rdfs:comment "Step in the extraction pipeline that produced this annotation."@en ;
    rdfs:range xsd:string .

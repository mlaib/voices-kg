PREFIX voices: <https://w3id.org/voices/ontology#>
PREFIX time: <http://www.w3.org/2006/time#>

# Events by temporal bucket
SELECT ?bucket (COUNT(?event) AS ?count)
WHERE {
  GRAPH <urn:voices:graph:events> {
    ?event a voices:NarratedEvent ;
           voices:temporalBucket ?bucket .
  }
}
GROUP BY ?bucket
ORDER BY ?bucket
